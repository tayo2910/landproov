<%- include('partials/head', { title: 'About Landproov — Real Proof. Real Ground.' }) %>
<%- include('partials/nav') %>

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Why we exist</p>
      <h1>Distance shouldn't mean losing control of what's yours</h1>
      <p>Every year, Nigerians abroad lose significant sums to land fraud, fake documents, and abandoned building projects — not because they weren't careful, but because they couldn't be there to check.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="approach-grid">
        <div class="approach-text">
          <h2>Our approach</h2>
          <p>Landproov places independent agents on the ground in Nigeria who work for you — not the seller, not the developer, not the contractor. Every visit is documented with timestamped photos, video, and GPS data, and every report goes straight to you, wherever you are in the world.</p>
        </div>
        <div></div>
      </div>

      <div class="pillars-grid">
        <div class="pillar-card">
          <h3>Independent</h3>
          <p>Our agents have no relationship with the seller, developer, or contractor being checked.</p>
        </div>
        <div class="pillar-card">
          <h3>Documented</h3>
          <p>Every visit produces a written report with photo and video evidence, kept on file.</p>
        </div>
        <div class="pillar-card">
          <h3>Wherever you are</h3>
          <p>UK, US, Canada or anywhere else — reports come to you, in your currency.</p>
        </div>
      </div>

      <div>
        <h2 class="about-subheading">How our agents are vetted</h2>
        <ul class="vetting-list">
          <li>Background and identity checks before joining the network</li>
          <li>Trained on Landproov's reporting standards and process</li>
          <li>Every report reviewed before it reaches you</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>We go there so you don't have to</h2>
      <p>Get in touch to discuss your property</p>
      <a href="/contact" class="btn btn-primary">Contact us</a>
    </div>
  </section>

<%- include('partials/footer') %>
