<%- include('partials/head', { title: 'Forgot Password' }) %>
<%- include('partials/nav') %>

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Reset password</p>
      <h1>Forgot your password?</h1>
      <p>Enter your email and we'll send you a reset link.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="auth-wrapper" style="max-width:440px;">
        <form id="forgotPasswordForm" class="auth-form" novalidate>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required>
          </div>
          <div id="formStatus" class="form-status" style="display:none;"></div>
          <button type="submit" class="btn btn-primary" id="submitBtn" style="width:100%;">Send reset link</button>
        </form>
        <p class="auth-alt"><a href="/login">Back to log in</a></p>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
