<%- include('partials/head') %>
<%- include('partials/nav') %>

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="eyebrow">For Nigerians in the diaspora</p>
        <h1>Real proof. Real ground.</h1>
        <p>Independent agents verify land, monitor your build, and manage your rental property in Nigeria — with reports sent directly to you, wherever you are.</p>
        <div class="btn-group">
          <a href="/contact" class="btn btn-primary">Get started</a>
          <a href="/services" class="btn btn-outline">View services</a>
        </div>
      </div>
      <div class="live-panel">
        <div class="live-panel-label"><span class="live-dot"></span> Live report — example</div>
        <ul class="live-panel-items">
          <li>Site visit — Lekki, Lagos</li>
          <li>Title verified — C of O confirmed</li>
          <li>14 photos, 2 videos attached</li>
          <li>Report sent to client</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="service-grid">
        <div class="service-card">
          <h3>Verification</h3>
          <p>Title checks &amp; registry searches</p>
          <div class="card-expanded">
            <p>We check title documents, confirm registry registration, and verify ownership history so you don't fall victim to land fraud.</p>
          </div>
          <button class="read-more">Read more</button>
        </div>
        <div class="service-card">
          <h3>Land Registration, Survey &amp; Documentation</h3>
          <p>Secure your title from start to finish</p>
          <div class="card-expanded">
            <p>We guide you through the entire land documentation process: conducting a thorough search at the land registry, processing the Certificate of Occupancy (C of O) or Governor's Consent, performing boundary surveys, and preparing Deeds of Assignment and all requisite conveyance documents. Every document is verified by a qualified legal partner before handover.</p>
          </div>
          <button class="read-more">Read more</button>
        </div>
        <div class="service-card">
          <h3>Quantity Survey</h3>
          <p>Independent cost assessments</p>
          <div class="card-expanded">
            <p>Our independent surveyors assess construction costs and materials stage by stage, ensuring you pay a fair price.</p>
          </div>
          <button class="read-more">Read more</button>
        </div>
        <div class="service-card">
          <h3>Project Monitoring</h3>
          <p>Ongoing site visits &amp; updates</p>
          <div class="card-expanded">
            <p>Our agents visit your site on a recurring schedule, document progress with photos and video, and flag delays or substandard work early.</p>
          </div>
          <button class="read-more">Read more</button>
        </div>

      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <p class="section-label">How it works</p>
      <div class="how-grid">
        <div class="step">
          <div class="step-number">01</div>
          <h3>Tell us what you need</h3>
          <p>Book through the enquiry form</p>
        </div>
        <div class="step">
          <div class="step-number">02</div>
          <h3>We go on-site</h3>
          <p>Independent, documented, on your behalf</p>
        </div>
        <div class="step">
          <div class="step-number">03</div>
          <h3>You get the report</h3>
          <p>Photos, video &amp; findings, wherever you are</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>Stop relying on phone calls and photos from family</h2>
      <p>Get an independent, documented view of your property — anywhere in the world</p>
      <a href="/signup?next=/contact" class="btn btn-primary consultation-btn">Book a consultation</a>
    </div>
  </section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
