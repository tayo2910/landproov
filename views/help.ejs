<%- include('partials/head', { title: 'Help & Support' }) %>
<%- include('partials/nav') %>

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Help &amp; Support</p>
      <h1>We're here to help</h1>
      <p>Find answers to common questions or get in touch with us directly.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">Frequently asked questions</p>

      <div style="display:flex;flex-direction:column;gap:24px;max-width:720px;">

        <div class="service-card" style="padding:24px 28px;">
          <h3 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--green);margin-bottom:6px;">How does Landproov verify my property?</h3>
          <p style="font-size:0.9375rem;color:var(--gray);line-height:1.7;">Our independent agents visit the property in person, check title documents at the land registry, take timestamped photos and video, and send you a detailed report with GPS confirmation.</p>
        </div>

        <div class="service-card" style="padding:24px 28px;">
          <h3 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--green);margin-bottom:6px;">How long does a verification take?</h3>
          <p style="font-size:0.9375rem;color:var(--gray);line-height:1.7;">Most verifications are completed within 3–5 working days. We'll keep you updated throughout the process.</p>
        </div>

        <div class="service-card" style="padding:24px 28px;">
          <h3 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--green);margin-bottom:6px;">Can I monitor ongoing construction from abroad?</h3>
          <p style="font-size:0.9375rem;color:var(--gray);line-height:1.7;">Yes. Our project monitoring plans include scheduled site visits with photo and video reports, so you can track progress wherever you are.</p>
        </div>

        <div class="service-card" style="padding:24px 28px;">
          <h3 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--green);margin-bottom:6px;">How do I pay?</h3>
          <p style="font-size:0.9375rem;color:var(--gray);line-height:1.7;">We accept payments in GBP, USD, and EUR. All fees are quoted in pounds sterling. Get in touch for a personalised quote.</p>
        </div>

        <div class="service-card" style="padding:24px 28px;">
          <h3 style="font-family:var(--font-serif);font-size:1.125rem;color:var(--green);margin-bottom:6px;">What areas do you cover in Nigeria?</h3>
          <p style="font-size:0.9375rem;color:var(--gray);line-height:1.7;">We currently operate across Lagos, Abuja, Port Harcourt, and major cities nationwide. Contact us to confirm coverage for your specific location.</p>
        </div>

      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>Still have questions?</h2>
      <p>Send us a message and we'll get back to you within one working day.</p>
      <a href="/contact" class="btn btn-primary">Contact us</a>
    </div>
  </section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
