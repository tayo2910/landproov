<%- include('partials/head', { title: 'Services — Land Verification & Property Management' }) %>
<%- include('partials/nav') %>

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">What we do</p>
      <h1>Six ways we're your eyes on the ground</h1>
      <p>Every service is carried out by an independent agent and documented for your records.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-list">
        <div class="service-item" id="verification">
          <div class="service-item-number">01</div>
          <div>
            <h3>Land &amp; Property Verification</h3>
            <p>We check title documents such as the Certificate of Occupancy and Deed of Assignment, confirm registration with the land registry, and verify the seller's ownership history.</p>
          </div>
        </div>
        <div class="service-item" id="land-registration">
          <div class="service-item-number">02</div>
          <div>
            <h3>Land Registration, Survey &amp; Documentation</h3>
            <p>End-to-end assistance with land title registration: survey and boundary mapping, processing of Certificate of Occupancy and Governor's Consent, preparation of Deeds of Assignment and conveyance documents, and verification by a qualified legal partner.</p>
          </div>
        </div>
        <div class="service-item" id="site-visits">
          <div class="service-item-number">03</div>
          <div>
            <h3>Site Visits &amp; Documentation</h3>
            <p>A physical inspection of the land or building, with timestamped photos and video, GPS location confirmation, and a written condition report.</p>
          </div>
        </div>
        <div class="service-item" id="quantity-surveying">
          <div class="service-item-number">04</div>
          <div>
            <h3>Quantity Surveying</h3>
            <p>An independent assessment of construction costs and materials, broken down stage by stage, so you know you're paying a fair price.</p>
          </div>
        </div>
        <div class="service-item" id="agent-meetings">
          <div class="service-item-number">05</div>
          <div>
            <h3>Agent &amp; Developer Meetings</h3>
            <p>We attend meetings with selling agents, developers, or contractors on your behalf, ask the right questions, and report back accurately.</p>
          </div>
        </div>
        <div class="service-item" id="project-monitoring">
          <div class="service-item-number">06</div>
          <div>
            <h3>Project Monitoring</h3>
            <p>Scheduled, recurring site visits during construction, with progress reports and early warning of delays or substandard work.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>Not sure which service you need?</h2>
      <p>Tell us about your property and we'll recommend the right starting point.</p>
      <a href="/signup?next=/contact" class="btn btn-primary consultation-btn">Book a consultation</a>
    </div>
  </section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
