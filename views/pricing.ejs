<%- include('partials/head', { title: 'Pricing — Land Verification & Property Management Costs' }) %>
<%- include('partials/nav') %>

  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Pricing</p>
      <h1>Pay for one visit, or ongoing peace of mind</h1>
      <p>Choose a one-off check, an ongoing monitoring plan, or rental management — whatever fits where you are right now.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <p class="section-label">One-off services</p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Document verification</h3>
          <div class="pricing-amount">From £150</div>
          <div class="pricing-sub">Title and ownership checks</div>
          <a href="/contact" class="btn btn-dark">Book now</a>
        </div>
        <div class="pricing-card">
          <h3>Site visit &amp; report</h3>
          <div class="pricing-amount">From £100</div>
          <div class="pricing-sub">Photos, video &amp; condition report</div>
          <a href="/contact" class="btn btn-dark">Book now</a>
        </div>
        <div class="pricing-card">
          <h3>Quantity Survey</h3>
          <div class="pricing-amount">From £300</div>
          <div class="pricing-sub">Independent cost assessment</div>
          <a href="/contact" class="btn btn-dark">Book now</a>
        </div>
      </div>

      <p class="section-label">Monthly monitoring</p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Basic</h3>
          <div class="pricing-amount">£80</div>
          <div class="pricing-sub">per month</div>
          <ul class="pricing-features">
            <li>One site visit per month</li>
            <li>Photo report</li>
          </ul>
          <a href="/contact" class="btn btn-dark">Get started</a>
        </div>
        <div class="pricing-card popular">
          <span class="popular-badge">Most popular</span>
          <h3>Standard</h3>
          <div class="pricing-amount">£150</div>
          <div class="pricing-sub">per month</div>
          <ul class="pricing-features">
            <li>Two site visits</li>
            <li>Video report</li>
            <li>Agent liaison</li>
          </ul>
          <a href="/contact" class="btn btn-primary">Get started</a>
        </div>
        <div class="pricing-card">
          <h3>Premium</h3>
          <div class="pricing-amount">£300</div>
          <div class="pricing-sub">per month</div>
          <ul class="pricing-features">
            <li>Weekly visits</li>
            <li>Live updates</li>
            <li>Quantity Survey oversight</li>
            <li>Legal support</li>
          </ul>
          <a href="/contact" class="btn btn-dark">Get started</a>
        </div>
      </div>

      <p class="section-label">Rental property management</p>
      <div class="rental-section">
        <h3>Rental property management</h3>
        <p>In Nigeria, rent is typically paid annually, so our fees are structured around the annual rent cycle.</p>
        <ul class="rental-fees">
          <li><strong>5–10%</strong> of agreed annual rent for tenant sourcing &amp; vetting</li>
          <li><strong>5–10%</strong> of annual rent collected &amp; remitted to you</li>
          <li><strong>Flat fee</strong> per visit for ongoing oversight, or a low retainer</li>
        </ul>
      </div>

    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>Need something tailored?</h2>
      <p>Major refurbishments and large projects are quoted separately based on scope.</p>
      <a href="/contact" class="btn btn-primary">Get a quote</a>
    </div>
  </section>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
