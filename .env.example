PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Contact form email — leave defaults to log to console in dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO=info@landproov.com
CONTACT_FROM=noreply@landproov.com

# Supabase — get these from Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Google reCAPTCHA v2 — get from https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# OpenAI — optional, only needed for AI chatbot
OPENAI_API_KEY=your-openai-api-key

# Exchange rate for Paystack NGN conversion
USD_TO_NGN_RATE=1500



